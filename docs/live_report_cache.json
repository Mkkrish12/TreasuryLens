  "sql_used": [
    "WITH top20 AS (SELECT address, eth_balance FROM CRYPTO.CRYPTO_ETHEREUM_CLASSIC.BALANCES ORDER BY eth_balance DESC LIMIT 20) SELECT address, eth_balance AS value_native, eth_balance / SUM(eth_balance) OVER () * 100 AS pct_of_total FROM top20 ORDER BY value_native DESC",
    "WITH chain_counts AS (SELECT 'CRYPTO_BITCOIN' AS chain, COUNT(*) AS transaction_count FROM CRYPTO.CRYPTO_BITCOIN.TRANSACTIONS UNION ALL SELECT 'CRYPTO_BITCOIN_CASH', COUNT(*) FROM CRYPTO.CRYPTO_BITCOIN_CASH.TRANSACTIONS UNION ALL SELECT 'CRYPTO_DASH', COUNT(*) FROM CRYPTO.CRYPTO_DASH.TRANSACTIONS UNION ALL SELECT 'CRYPTO_ETHEREUM', COUNT(*) FROM CRYPTO.CRYPTO_ETHEREUM.TRANSACTIONS UNION ALL SELECT 'CRYPTO_BAND', COUNT(*) FROM CRYPTO.CRYPTO_BAND.TRANSACTIONS) SELECT chain, transaction_count AS total_native_amount, ROUND(100.0 * transaction_count / SUM(transaction_count) OVER (), 2) AS pct_of_total FROM chain_counts ORDER BY transaction_count DESC",
    "SELECT from_address AS address, MAX(TO_TIMESTAMP(block_timestamp, 6)) AS last_tx_timestamp, DATEDIFF('day', MAX(TO_TIMESTAMP(block_timestamp, 6)), CURRENT_TIMESTAMP()) AS days_since_last_tx, COUNT(*) AS tx_count_30d, APPROX_COUNT_DISTINCT(to_address) AS unique_counterparties FROM CRYPTO.CRYPTO_ETHEREUM.TRANSACTIONS WHERE from_address IS NOT NULL AND TO_TIMESTAMP(block_timestamp, 6) >= DATEADD(year, -1, TO_TIMESTAMP(1719964800000000, 6)) GROUP BY from_address QUALIFY RANK() OVER (ORDER BY COUNT(*) DESC) <= 50 ORDER BY last_tx_timestamp DESC LIMIT 15"
  ],
